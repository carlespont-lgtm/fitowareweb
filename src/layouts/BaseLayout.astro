---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppWidget from '../components/WhatsAppWidget.astro';
import CookieConsent from '../components/CookieConsent.astro';
import ScrollTop from '../components/ScrollTop.astro';
import { getLocaleFromUrl, useTranslations, getAlternatePath, localePrefix, type Locale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  image?: string;
  alternates?: Partial<Record<Locale, string>>;
}
const { title, description, noindex, image, alternates } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const altPath = (l: Locale): string => alternates?.[l] ?? getAlternatePath(Astro.url, l);
const ogImage = new URL(image ?? '/photos/invernadero-hileras.png', Astro.site).href;
const ogLocaleAlt: Record<Locale, string> = { ca: 'ca_ES', es: 'es_ES', en: 'en_US' };

const pageTitle = title ? `${title} · ${t('site.name')}` : `${t('site.name')} — ${t('site.tagline')}`;
const pageDesc = description ?? t('site.desc');

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogLocaleMap: Record<Locale, string> = { ca: 'ca_ES', es: 'es_ES', en: 'en_US' };

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Fitoware',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web, Microsoft Dynamics 365 Business Central',
  description: t('site.desc'),
  url: 'https://fitoware.com',
  publisher: {
    '@type': 'Organization',
    name: 'Slave Computers, S.L.',
    url: 'https://slave.net',
    parentOrganization: { '@type': 'Organization', name: 'SIAM Cloud', url: 'https://siamcloud.es' },
  },
};
---
<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('reveal-ready');</script>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonical.href} />
    <link rel="alternate" hreflang="ca" href={new URL(altPath('ca'), Astro.site).href} />
    <link rel="alternate" hreflang="es" href={new URL(altPath('es'), Astro.site).href} />
    <link rel="alternate" hreflang="en" href={new URL(altPath('en'), Astro.site).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(altPath('ca'), Astro.site).href} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fitoware" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:locale" content={ogLocaleMap[locale]} />
    {(['ca', 'es', 'en'] as Locale[]).filter((l) => l !== locale).map((l) => (
      <meta property="og:locale:alternate" content={ogLocaleAlt[l]} />
    ))}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col bg-white">
    <div id="scroll-progress" aria-hidden="true"></div>
    <Header locale={locale} alternates={alternates} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <WhatsAppWidget locale={locale} />
    <ScrollTop locale={locale} />
    <CookieConsent locale={locale} />

    <!-- Lightbox global: amplía cualquier imagen de contenido, con navegación de galería -->
    <div id="fito-lightbox" class="fito-lightbox" role="dialog" aria-modal="true" aria-label={t('lightbox.close')}>
      <button type="button" class="fito-lightbox__close" aria-label={t('lightbox.close')}>
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
      <button type="button" class="fito-lightbox__nav fito-lightbox__prev" aria-label={t('lightbox.prev')}>
        <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6" /></svg>
      </button>
      <button type="button" class="fito-lightbox__nav fito-lightbox__next" aria-label={t('lightbox.next')}>
        <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6" /></svg>
      </button>
      <img alt="" />
    </div>

    <script is:inline>
      (function () {
        function initLightbox() {
          var box = document.getElementById('fito-lightbox');
          if (!box) return;
          var boxImg = box.querySelector('img');
          var closeBtn = box.querySelector('.fito-lightbox__close');
          var prevBtn = box.querySelector('.fito-lightbox__prev');
          var nextBtn = box.querySelector('.fito-lightbox__next');
          var lastFocus = null;
          var group = [];   // elementos <img> de la galería actual
          var idx = 0;
          function render() {
            var img = group[idx];
            if (!img) return;
            boxImg.setAttribute('src', img.currentSrc || img.getAttribute('src'));
            boxImg.setAttribute('alt', img.getAttribute('alt') || '');
            var many = group.length > 1;
            box.classList.toggle('has-nav', many);
          }
          function openFrom(img) {
            var gal = img.getAttribute('data-gallery');
            if (gal) {
              group = [].slice.call(document.querySelectorAll('main img[data-gallery="' + gal + '"]'));
            } else {
              group = [img];
            }
            idx = Math.max(0, group.indexOf(img));
            render();
            box.classList.add('is-open');
            document.documentElement.style.overflow = 'hidden';
            lastFocus = document.activeElement;
            closeBtn.focus();
          }
          function step(d) {
            if (group.length < 2) return;
            idx = (idx + d + group.length) % group.length;
            render();
          }
          function close() {
            box.classList.remove('is-open');
            document.documentElement.style.overflow = '';
            boxImg.setAttribute('src', '');
            group = [];
            if (lastFocus && lastFocus.focus) lastFocus.focus();
          }
          if (!box.dataset.bound) {
            box.dataset.bound = '1';
            box.addEventListener('click', function (e) { if (e.target === box) close(); });
            closeBtn.addEventListener('click', close);
            prevBtn.addEventListener('click', function (e) { e.stopPropagation(); step(-1); });
            nextBtn.addEventListener('click', function (e) { e.stopPropagation(); step(1); });
            document.addEventListener('keydown', function (e) {
              if (!box.classList.contains('is-open')) return;
              if (e.key === 'Escape') close();
              else if (e.key === 'ArrowLeft') step(-1);
              else if (e.key === 'ArrowRight') step(1);
            });
          }
          var imgs = document.querySelectorAll('main img');
          imgs.forEach(function (img) {
            if (img.dataset.zoomBound) return;
            if (img.closest('a')) return;                 // enlace: navega, no amplía
            if (img.hasAttribute('data-no-zoom')) return;
            if (img.getAttribute('alt') === '') return;    // decorativa
            var w = img.clientWidth || img.naturalWidth || 0;
            if (w && w < 80) return;                       // icono/logo pequeño
            img.dataset.zoomBound = '1';
            img.setAttribute('data-zoomable', '');
            img.addEventListener('click', function () { openFrom(img); });
          });
        }
        document.addEventListener('astro:page-load', initLightbox);
        if (document.readyState !== 'loading') initLightbox();
        else document.addEventListener('DOMContentLoaded', initLightbox);
      })();
    </script>

    <script is:inline>
      (function () {
        function setupReveal() {
          var els = document.querySelectorAll('.reveal:not(.is-visible), .reveal-blur:not(.is-visible)');
          if (!('IntersectionObserver' in window)) {
            els.forEach(function (e) { e.classList.add('is-visible'); });
            return;
          }
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (en) {
                if (en.isIntersecting) {
                  var el = en.target;
                  // Revelado en cascada: pequeño retardo según la posición entre hermanos
                  if (el.parentElement) {
                    var sibs = [].slice.call(el.parentElement.children).filter(function (c) {
                      return c.classList && (c.classList.contains('reveal') || c.classList.contains('reveal-blur'));
                    });
                    var i = sibs.indexOf(el);
                    if (i > 0) {
                      var d = Math.min(i, 8) * 65 + 'ms';
                      el.style.transitionDelay = d;
                      el.style.animationDelay = d;
                    }
                  }
                  el.classList.add('is-visible');
                  io.unobserve(el);
                }
              });
            },
            { threshold: 0.08, rootMargin: '0px 0px -8% 0px' }
          );
          els.forEach(function (e) { io.observe(e); });
          // Red de seguridad: si algo no se revela (navegación, timing…), mostrarlo igualmente.
          setTimeout(function () {
            document.querySelectorAll('.reveal:not(.is-visible), .reveal-blur:not(.is-visible)').forEach(function (e) { e.classList.add('is-visible'); });
          }, 1600);
        }
        document.addEventListener('astro:page-load', setupReveal);
        if (document.readyState !== 'loading') setupReveal();
        else document.addEventListener('DOMContentLoaded', setupReveal);
      })();
    </script>

    <script is:inline>
      (function () {
        if (window.__fitoProgress) return;
        window.__fitoProgress = true;
        var ticking = false;
        function update() {
          ticking = false;
          var bar = document.getElementById('scroll-progress');
          if (!bar) return;
          var h = document.documentElement;
          var max = h.scrollHeight - h.clientHeight;
          var p = max > 0 ? h.scrollTop / max : 0;
          bar.style.transform = 'scaleX(' + Math.min(1, Math.max(0, p)) + ')';
        }
        function onScroll() {
          if (!ticking) { ticking = true; requestAnimationFrame(update); }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        document.addEventListener('astro:page-load', update);
        update();
      })();
    </script>
  </body>
</html>
