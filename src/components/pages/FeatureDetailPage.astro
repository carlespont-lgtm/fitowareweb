---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import { featureList, featurePath, featureMockup } from '../../i18n/features';
import Icon from '../Icon.astro';

interface Props {
  locale: Locale;
  featureKey: string;
}
const { locale, featureKey } = Astro.props;
const t = useTranslations(locale);

const feature = featureList.find((f) => f.key === featureKey)!;
const related = featureList.filter((f) => f.key !== featureKey);
const bullets = ['b1', 'b2', 'b3'];
---
<!-- HERO -->
<section class="relative overflow-hidden border-b border-slate-100 bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="fito-dots absolute inset-0 opacity-40"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-14 sm:py-16">
    <a href={localizedPath('features', locale)} class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-100/80 transition hover:text-white">
      <Icon name="arrow" class="h-4 w-4 rotate-180" /> {t('features.eyebrow')}
    </a>
    <div class="mt-6 grid items-center gap-10 lg:grid-cols-2">
      <div>
        <span class="grid h-14 w-14 place-items-center rounded-2xl text-white shadow-lg" style={`background:linear-gradient(135deg, ${feature.grad[0]}, ${feature.grad[1]})`}>
          <Icon name={feature.icon} class="h-7 w-7" />
        </span>
        <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{t(`feat.${feature.key}.t`)}</h1>
        <p class="mt-4 text-lg leading-relaxed text-brand-50/85">{t(`fdet.${feature.key}.lead`)}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={localizedPath('contact', locale)} class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-brand-400">
            {t('cta.button')} <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href={localizedPath('editions', locale)} class="inline-flex items-center gap-2 rounded-lg border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/15">
            {t('nav.editions')}
          </a>
        </div>
      </div>
      <div class="reveal is-visible overflow-hidden rounded-2xl border border-white/10 shadow-2xl">
        <img src={featureMockup(feature, locale)} alt={t(`feat.${feature.key}.t`)} width="760" height="480" class="w-full" />
      </div>
    </div>
  </div>
</section>

<!-- QUÉ INCLUYE -->
<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('fdet.benefits')}</p>
    <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{t(`feat.${feature.key}.d`)}</h2>
    <div class="mt-10 grid gap-5 sm:grid-cols-3">
      {
        bullets.map((b) => (
          <div class="reveal rounded-2xl border border-slate-100 bg-slate-50/60 p-6">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-100 text-brand-700">
              <Icon name="check-circle" class="h-5 w-5" />
            </span>
            <p class="mt-4 text-sm leading-relaxed text-slate-700">{t(`fdet.${feature.key}.${b}`)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- OTRAS FUNCIONALIDADES -->
<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('fdet.related')}</p>
    <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
      {
        related.map((f) => (
          <a href={featurePath(f.key, locale)} class="group flex flex-col rounded-2xl border border-slate-100 bg-white p-5 transition hover:-translate-y-1 hover:shadow-md">
            <span class="grid h-10 w-10 place-items-center rounded-xl text-white shadow-sm" style={`background:linear-gradient(135deg, ${f.grad[0]}, ${f.grad[1]})`}>
              <Icon name={f.icon} class="h-5 w-5" />
            </span>
            <h3 class="mt-4 text-sm font-bold text-ink-900 group-hover:text-brand-700">{t(`feat.${f.key}.t`)}</h3>
            <span class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-brand-600">
              {t('fdet.see')} <Icon name="arrow" class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-gradient-to-br from-brand-600 to-brand-800 py-16">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-2xl font-extrabold tracking-tight text-white sm:text-3xl">{t('cta.title')}</h2>
    <p class="mt-4 text-brand-50/90">{t('cta.subtitle')}</p>
    <a href={localizedPath('contact', locale)} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-7 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition hover:bg-brand-50">
      {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
    </a>
  </div>
</section>
