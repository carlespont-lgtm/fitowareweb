---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import { operationList, operationPath, operationImage } from '../../i18n/operations';
import { editionPath } from '../../i18n/editions';
import Icon from '../Icon.astro';

interface Props {
  locale: Locale;
  operationKey: string;
}
const { locale, operationKey } = Astro.props;
const t = useTranslations(locale);

const op = operationList.find((o) => o.key === operationKey)!;
const related = operationList.filter((o) => o.category === op.category && o.key !== operationKey).slice(0, 5);
const bullets = ['b1', 'b2', 'b3', 'b4'];
const aiDiagram = `/mockups/ai-agente${locale === 'ca' ? '-ca' : locale === 'en' ? '-en' : ''}.svg`;
---
<!-- HERO -->
<section class="relative overflow-hidden border-b border-slate-100 bg-gradient-to-br from-ink-950 via-ink-900 to-brand-800">
  <div class="fito-dots absolute inset-0 opacity-40"></div>
  <div class="relative mx-auto max-w-6xl px-4 py-14 sm:py-16">
    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm font-medium text-brand-100/80">
      <a href={editionPath('bc', locale)} class="inline-flex items-center gap-1.5 transition hover:text-white">
        <Icon name="arrow" class="h-4 w-4 rotate-180" /> {t('ed.bc.name')}
      </a>
      <span class="text-brand-100/40">·</span>
      <span class="text-brand-100/70">{t('ops.eyebrow')}</span>
    </div>
    <div class="mt-6 grid items-center gap-10 lg:grid-cols-2">
      <div>
        <span class="grid h-14 w-14 place-items-center rounded-2xl bg-brand-500/20 text-leaf-300 ring-1 ring-white/10">
          <Icon name={op.icon} class="h-7 w-7" />
        </span>
        <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">{t(`ops.${op.key}.title`)}</h1>
        <p class="mt-2 text-lg font-semibold text-brand-200">{t(`ops.${op.key}.sub`)}</p>
        <p class="mt-4 text-lg leading-relaxed text-brand-50/85">{t(`ops.${op.key}.lead`)}</p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={localizedPath('contact', locale)} class="inline-flex items-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white shadow-lg transition hover:bg-brand-400">
            {t('cta.button')} <Icon name="arrow" class="h-4 w-4" />
          </a>
          <a href={editionPath('bc', locale)} class="inline-flex items-center gap-2 rounded-lg border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/15">
            {t('ops.back')}
          </a>
        </div>
      </div>
      <div class="reveal-blur is-visible photo-frame aspect-[16/10] border border-white/10 shadow-2xl">
        <img src={operationImage(op, locale)} alt={t(`ops.${op.key}.title`)} loading="lazy" />
      </div>
    </div>
  </div>
</section>

<!-- QUÉ RESUELVE -->
<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('ops.included')}</p>
    <h2 class="mt-3 max-w-3xl text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{t(`ops.${op.key}.title`)}</h2>
    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {
        bullets.map((b) => (
          <div class="reveal flex items-start gap-4 rounded-2xl border border-slate-100 bg-slate-50/60 p-6">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-brand-100 text-brand-700">
              <Icon name="check" class="h-5 w-5" />
            </span>
            <p class="text-sm leading-relaxed text-slate-700">{t(`ops.${op.key}.${b}`)}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

{op.key === 'ai' && (
  <section class="bg-slate-50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 text-center">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('ops.ai.agent.eyebrow')}</p>
      <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-ink-900 sm:text-3xl">{t('ops.ai.agent.title')}</h2>
      <div class="reveal-blur mt-10 overflow-hidden rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <img src={aiDiagram} alt={t('ops.ai.agent.title')} loading="lazy" class="mx-auto w-full" />
      </div>
    </div>
  </section>
)}

<!-- OTRAS ÁREAS -->
<section class="bg-slate-50 py-16 sm:py-20">
  <div class="mx-auto max-w-6xl px-4">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('ops.related')}</p>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
      {
        related.map((o) => (
          <a href={operationPath(o.key, locale)} class="group flex flex-col rounded-2xl border border-slate-100 bg-white p-5 transition hover:-translate-y-1 hover:shadow-md">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-100 text-brand-700">
              <Icon name={o.icon} class="h-5 w-5" />
            </span>
            <h3 class="mt-4 text-sm font-bold text-ink-900 group-hover:text-brand-700">{t(`ops.${o.key}.title`)}</h3>
            <span class="mt-2 inline-flex items-center gap-1 text-xs font-semibold text-brand-600">
              {t('fdet.see')} <Icon name="arrow" class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" />
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-gradient-to-br from-brand-600 to-brand-800 py-16">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-2xl font-extrabold tracking-tight text-white sm:text-3xl">{t('cta.title')}</h2>
    <p class="mt-4 text-brand-50/90">{t('cta.subtitle')}</p>
    <a href={localizedPath('contact', locale)} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-white px-7 py-3.5 text-base font-semibold text-brand-700 shadow-lg transition hover:bg-brand-50">
      {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
    </a>
  </div>
</section>
