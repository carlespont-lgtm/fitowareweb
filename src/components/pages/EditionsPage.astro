---
import { useTranslations, localizedPath, type Locale } from '../../i18n/utils';
import Icon from '../Icon.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
---
<!-- HEADER -->
<section class="border-b border-slate-100 bg-gradient-to-b from-slate-50 to-white">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:py-20">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('editions.eyebrow')}</p>
    <h1 class="mt-3 max-w-3xl text-4xl font-extrabold tracking-tight text-ink-900 sm:text-5xl">{t('editions.title')}</h1>
    <p class="mt-5 max-w-2xl text-lg text-slate-600">{t('editions.subtitle')}</p>
  </div>
</section>

<!-- EDICIONES -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Business Central / IONNAVIS -->
      <div class="reveal flex flex-col rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <span class="inline-flex w-fit items-center gap-1.5 rounded-full bg-ink-900/5 px-3 py-1 text-xs font-semibold text-ink-800">
          <Icon name="cloud" class="h-3.5 w-3.5" /> {t('ed.bc.tag')}
        </span>
        <h2 class="mt-4 text-2xl font-bold text-ink-900">{t('ed.bc.name')}</h2>
        <p class="mt-1 text-sm font-semibold text-brand-700">{t('ed.bc.platform')}</p>
        <p class="mt-5 flex-1 leading-relaxed text-slate-600">{t('ed.bc.d')}</p>
        <div class="mt-6 flex items-center gap-3 rounded-xl bg-slate-50 p-4">
          <img src="/brand/ionnavis.svg" alt="IONNAVIS" width="44" height="44" class="h-11 w-11 rounded-lg" />
          <div class="text-sm">
            <p class="font-semibold text-ink-900">Partner IONNAVIS</p>
            <p class="text-slate-500">Implantación y soporte · Microsoft Dynamics 365</p>
          </div>
        </div>
        <a href="https://www.ionnavis.com" target="_blank" rel="noopener" class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg bg-ink-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-ink-800">
          {t('ed.bc.cta')} <Icon name="external" class="h-4 w-4" />
        </a>
      </div>

      <!-- GestioERP -->
      <div class="reveal flex flex-col rounded-2xl border-2 border-brand-500 bg-white p-8 shadow-sm">
        <span class="inline-flex w-fit items-center gap-1.5 rounded-full bg-brand-100 px-3 py-1 text-xs font-semibold text-brand-700">
          <Icon name="sparkles" class="h-3.5 w-3.5" /> {t('ed.ge.tag')}
        </span>
        <h2 class="mt-4 text-2xl font-bold text-ink-900">{t('ed.ge.name')}</h2>
        <p class="mt-1 text-sm font-semibold text-brand-700">{t('ed.ge.platform')}</p>
        <p class="mt-5 flex-1 leading-relaxed text-slate-600">{t('ed.ge.d')}</p>
        <div class="mt-6 flex items-center gap-3 rounded-xl bg-brand-50 p-4">
          <span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-600 text-white">
            <Icon name="cloud" class="h-5 w-5" />
          </span>
          <div class="text-sm">
            <p class="font-semibold text-ink-900">GestioERP</p>
            <p class="text-slate-500">ERP en la nube · grupo SIAM Cloud</p>
          </div>
        </div>
        <a href="https://gestioerp.com" target="_blank" rel="noopener" class="mt-6 inline-flex items-center justify-center gap-2 rounded-lg bg-brand-500 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-600">
          {t('ed.ge.cta')} <Icon name="external" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div class="mt-10 flex items-start gap-3 rounded-2xl border border-brand-100 bg-brand-50/50 p-6">
      <Icon name="check-circle" class="mt-0.5 h-6 w-6 shrink-0 text-brand-600" />
      <p class="text-slate-700">{t('editions.regulation')}</p>
    </div>
  </div>
</section>

<!-- NORMATIVA -->
<section class="bg-slate-50 py-20">
  <div class="mx-auto grid max-w-6xl items-center gap-10 px-4 lg:grid-cols-2">
    <div class="reveal">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('reg.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('reg.title')}</h2>
      <p class="mt-4 text-slate-600">{t('reg.desc')}</p>
    </div>
    <ul class="reveal space-y-4">
      {
        ['reg.b1', 'reg.b2', 'reg.b3'].map((k) => (
          <li class="flex items-start gap-3 rounded-xl border border-slate-200 bg-white p-4 text-sm text-slate-700">
            <Icon name="check-circle" class="mt-0.5 h-5 w-5 shrink-0 text-brand-600" />
            {t(k)}
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- COMPARATIVA -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-5xl px-4">
    <div class="max-w-2xl">
      <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('compare.eyebrow')}</p>
      <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('compare.title')}</h2>
      <p class="mt-4 text-lg text-slate-600">{t('compare.subtitle')}</p>
    </div>
    <div class="mt-10 overflow-x-auto">
      <table class="w-full min-w-[560px] text-left text-sm">
        <thead>
          <tr class="border-b border-slate-200">
            <th class="py-4 pr-4"></th>
            <th class="rounded-t-xl bg-brand-50 px-5 py-4 text-base font-bold text-brand-800">{t('compare.col.ge')}</th>
            <th class="px-5 py-4 text-base font-bold text-ink-900">{t('compare.col.bc')}</th>
          </tr>
        </thead>
        <tbody>
          {
            ['r1', 'r2', 'r3', 'r4'].map((r) => (
              <tr class="border-b border-slate-100">
                <td class="py-4 pr-4 font-semibold text-slate-500">{t(`compare.${r}`)}</td>
                <td class="bg-brand-50/50 px-5 py-4 font-medium text-ink-900">{t(`compare.${r}.ge`)}</td>
                <td class="px-5 py-4 text-slate-700">{t(`compare.${r}.bc`)}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="bg-slate-50 py-20">
  <div class="mx-auto max-w-3xl px-4">
    <p class="text-sm font-bold uppercase tracking-widest text-brand-600">{t('faq.eyebrow')}</p>
    <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('faq.title')}</h2>
    <div class="mt-8 space-y-3">
      {
        ['1', '2', '3', '4', '5'].map((n) => (
          <details class="group rounded-xl border border-slate-200 bg-white p-5">
            <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-ink-900">
              {t(`faq.q${n}`)}
              <span class="ml-4 text-xl leading-none text-brand-600 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-slate-600">{t(`faq.a${n}`)}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<!-- CTA -->
<section class="bg-white py-20">
  <div class="mx-auto max-w-3xl px-4 text-center">
    <h2 class="text-3xl font-extrabold tracking-tight text-ink-900 sm:text-4xl">{t('cta.title')}</h2>
    <p class="mt-4 text-lg text-slate-600">{t('cta.subtitle')}</p>
    <a href={localizedPath('contact', locale)} class="mt-8 inline-flex items-center gap-2 rounded-lg bg-brand-500 px-7 py-3.5 text-base font-semibold text-white shadow-sm transition hover:bg-brand-600">
      {t('cta.button')} <Icon name="arrow" class="h-5 w-5" />
    </a>
  </div>
</section>
