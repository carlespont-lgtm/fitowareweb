---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EditionDetailPage from '../../components/pages/EditionDetailPage.astro';
import { editionList, editionAlternates } from '../../i18n/editions';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return editionList.map((e) => ({
    params: { edition: e.slug },
    props: { editionKey: e.key },
  }));
}

const { editionKey } = Astro.props;
const t = useTranslations('ca');
const alternates = editionAlternates(editionKey);
---
<BaseLayout title={t(`ed.${editionKey}.name`)} description={t(`edet.${editionKey}.lead`)} alternates={alternates}>
  <EditionDetailPage locale="ca" editionKey={editionKey} />
</BaseLayout>
