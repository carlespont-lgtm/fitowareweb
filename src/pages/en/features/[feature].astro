---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FeatureDetailPage from '../../../components/pages/FeatureDetailPage.astro';
import { featureList, featureAlternates } from '../../../i18n/features';
import { useTranslations } from '../../../i18n/utils';

export function getStaticPaths() {
  return featureList.map((f) => ({
    params: { feature: f.slug.en },
    props: { featureKey: f.key },
  }));
}

const { featureKey } = Astro.props;
const t = useTranslations('en');
const alternates = featureAlternates(featureKey);
---
<BaseLayout title={t(`feat.${featureKey}.t`)} description={t(`feat.${featureKey}.d`)} alternates={alternates}>
  <FeatureDetailPage locale="en" featureKey={featureKey} />
</BaseLayout>
